POSTGRES_DB=testdb
POSTGRES_USER=test_constructor
POSTGRES_PASSWORD=change-me-strong-postgres-password
JWT_SECRET=change-me-long-random-jwt-secret
JWT_EXPIRE=7d
NODE_ENV=production

# Browser-visible API origin. Use your server IP or domain, without a trailing slash.
# Examples:
# REACT_APP_API_URL=http://203.0.113.10
# REACT_APP_API_URL=https://tests.example.com
REACT_APP_API_URL=http://YOUR_SERVER_IP_OR_DOMAIN
